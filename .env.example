# ════════════════════════════════════════════════════════════════════
# TIN HỌC TRẺ — Environment Variables
# Sao chép file này thành .env và điền các giá trị thực
# cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# ── Supabase (Bắt buộc) ─────────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── PostgreSQL / Supabase Direct (Bắt buộc cho tin-hoc-tre-api) ─────
# Lấy từ: Supabase Dashboard → Settings → Database → Connection String
# Nếu dùng DATABASE_URL thì các biến DB_* sẽ bị bỏ qua
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Hoặc điền riêng lẻ nếu không dùng DATABASE_URL:
# DB_HOST=db.your-project.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASS=your-db-password

# ── Redis (Trạm hàng đợi chấm bài) ─────────────────────────────────
# Khi dùng docker-compose, giá trị này là "redis" (tên service)
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT / Auth ──────────────────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Hoặc dùng legacy key:
# JWT_SECRET=your-legacy-jwt-secret

# ── API Server ──────────────────────────────────────────────────────
PORT=3000
# Cho phép CORS từ các frontend này (ngăn cách bởi dấu phẩy nếu nhiều)
FRONTEND_ORIGIN=https://your-react-quest-app.netlify.app,https://your-contest-dashboard.netlify.app

NODE_ENV=production

# ── Judge Worker ────────────────────────────────────────────────────
# Giới hạn thời gian chấm bài (ms)
JUDGE_TIME_LIMIT_MS=5000
# Giới hạn bộ nhớ judge (MB)
JUDGE_MEMORY_MB=256

# ── Piston Judge (tùy chọn — cho bài nộp ngôn ngữ khác) ────────────
PISTON_URL=https://piston.orchable.xyz/api/v2
