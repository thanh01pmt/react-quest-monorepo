{
  "name": "react-quest-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:templates": "turbo build --filter=@repo/shared-templates",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "sync-problems": "pnpm tsx scripts/sync-problems.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.1.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "blockly": "12.3.1",
      "three": "^0.162.0",
      "@types/three": "^0.162.0"
    }
  },
  "version": "0.0.1"
}
