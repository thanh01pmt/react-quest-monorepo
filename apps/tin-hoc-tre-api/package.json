{
  "name": "tin-hoc-tre-contest-platform",
  "version": "1.0.0",
  "description": "Hệ thống thi lập trình Scratch nội bộ đồng dạng Tin học trẻ",
  "private": true,
  "engines": { "node": ">=18" },
  "scripts": {
