    "helmet":       "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan":       "^1.10.0",
    "multer":       "^1.4.5-lts.1",
    "pg":           "^8.11.3",
    "uuid":         "^9.0.1",
    "@tin-hoc-tre/shared": "workspace:*",
    "@tin-hoc-tre/problems": "workspace:*",
    "@supabase/supabase-js": "^2.39.7"
