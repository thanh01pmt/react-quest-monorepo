# Sao chép file này thành .env và điền giá trị thực
# cp .env.example .env

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tinhoctre
DB_USER=postgres
DB_PASS=your_password_here

# ── Redis (Bull queue) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ─────────────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=THAY_BANG_CHUOI_NGAU_NHIEN_64_KY_TU

# ── Server ───────────────────────────────────────────────────────
PORT=3000
FRONTEND_ORIGIN=http://localhost:8080

# ── Contest ──────────────────────────────────────────────────────
# Thời điểm bắt đầu cuộc thi (ISO 8601, UTC)
CONTEST_START_TIME=2025-06-01T07:30:00Z

# ── Judge ────────────────────────────────────────────────────────
JUDGE_TIME_LIMIT_MS=5000
JUDGE_MEMORY_MB=256
