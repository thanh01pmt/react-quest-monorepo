{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "vite/client",
      "node"
    ],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      // Ánh xạ tên package đến mã nguồn thực tế của nó
      "@repo/quest-player": [
        "../../packages/quest-player/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "../../packages/quest-player/src/custom.d.ts",
    "../../packages/academic-map-generator/src/declarations.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../../packages/quest-player"
    }
  ]
}