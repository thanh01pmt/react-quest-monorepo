{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": ["src/**", "templates/**/*.md", "package.json", "tsconfig.json"],
      "outputs": [
        "dist/**"
      ]
    },
    "lint": {}
  }
}